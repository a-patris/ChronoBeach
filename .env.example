# Firebase (optionnel — sans ces variables, ChronoBeach reste en localStorage)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Auth : activer « E-mail/Mot de passe » et « Anonyme » dans Firebase Console
# Super admin (e-mails séparés par des virgules — aligné avec firestore.rules)
VITE_SUPER_ADMIN_EMAILS=

# Contact commercial (fallback mode local sans Firebase)
VITE_CONTACT_EMAIL=

# Cloud Functions — variables d'environnement côté Firebase/GCP (pas Vercel)
# ADMIN_NOTIFY_EMAIL=
# APP_ADMIN_URL=
# SMTP_USER=
# SMTP_PASSWORD=

# Déployer : firebase deploy --only firestore,functions
