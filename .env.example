# Firebase (optionnel — sans ces variables, ChronoBeach reste en localStorage)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Auth : activer aussi « Connexion anonyme » dans Firebase Console (codes table de marque)
# Super admin (e-mails séparés par des virgules — doit correspondre à firestore.rules)
VITE_SUPER_ADMIN_EMAILS=votre.email@exemple.com

# Auth : créer les comptes organisateurs dans Firebase Console → Authentication → Utilisateurs
# Firestore : publier firestore.rules (lecture display/classement, écriture authentifiée)
