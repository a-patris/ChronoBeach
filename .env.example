# Firebase (optionnel — sans ces variables, ChronoBeach reste en localStorage)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Auth : activer aussi « Connexion anonyme » dans Firebase Console (codes table de marque)
# Super admin (e-mails séparés par des virgules — doit correspondre à firestore.rules)
VITE_SUPER_ADMIN_EMAILS=votre.email@exemple.com

# Contact commercial (fallback mode local sans Firebase)
VITE_CONTACT_EMAIL=votre.email@exemple.com

# Cloud Function notifyActivationRequest (deploy functions/)
# ADMIN_NOTIFY_EMAIL=amaury.patris@gmail.com
# APP_ADMIN_URL=https://chrono-beach.vercel.app/users
# SMTP : la function lit le secret Gmail de l'extension firestore-send-email-SMTP_PASSWORD
#        ou SMTP_PASSWORD / SMTP_USER en variables d'environnement Cloud Function

# Auth : créer les comptes organisateurs dans Firebase Console → Authentication → Utilisateurs
# Firestore : publier firestore.rules (lecture display/classement, écriture authentifiée)
